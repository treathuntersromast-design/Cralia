# ================================================================
# Cralia .gitignore
# ================================================================

# ── 依存パッケージ ────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js ビルド成果物 ─────────────────────────────────────────
.next/
out/
dist/
build/

# ── 環境変数（機密情報）─────────────────────────────────────────
# .env.example / .env.sample はコミット可（テンプレート用途）
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# ── テスト・カバレッジ ────────────────────────────────────────────
coverage/
.vitest/
.pytest_cache/
__pycache__/
*.pyc
*.pyo

# ── OS 生成ファイル ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ── エディタ ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-workspace
*.sublime-project

# ── Claude Code ──────────────────────────────────────────────────
# settings はプロジェクト固有設定のため除外
.claude/settings.json
.claude/settings.local.json
# skills はダウンロード済みツール（node_modules 相当）
.claude/skills/
skills/

# ── デバッグ・ログ ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── オフィスツール一時ファイル ────────────────────────────────────
# LibreOffice ロックファイル
.~lock.*
# Microsoft Office 一時ファイル（~$から始まる）
~$*

# ── Supabase 一時マイグレーション ────────────────────────────────
# migrate.sql は実行後に削除するルールだが、削除忘れ防止の安全網
supabase/migrate.sql

# ── CI / デプロイ ────────────────────────────────────────────────
.vercel/
.turbo/
.output/

# ── Yarn Berry（将来の移行に備えて） ────────────────────────────
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
